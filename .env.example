# PostgreSQL connection (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transfodb?schema=public

# iron-session cookie encryption — min 32 characters (required)
SESSION_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Optional: Admin AI chat (Groq)
# GROQ_API_KEY=

# Optional: password used only when seed creates the admin user
# SEED_ADMIN_PASSWORD=ChangeMe1!
