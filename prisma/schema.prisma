generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Chantier {
  id                     String                 @id @default(uuid())
  code                   String                 @unique
  nom                    String
  description            String                 @default("")
  domaine                String
  type_chantier          String                 @default("")
  priorite               String                 @default("")
  duree_mois             Int                    @default(0)
  budget                 Float                  @default(0)
  budgetJH               Float                  @default(0)
  budgetProjetMAD        Float                  @default(0)
  conseilEditeursMAD     Float                  @default(0)
  licencesAchatsMAD      Float                  @default(0)
  licencesAbonnementsMAD Float                  @default(0)
  coutsInfrasMAD         Float                  @default(0)
  budgetTotalMAD         Float                  @default(0)
  directeur              String                 @default("")
  pmo                    String                 @default("")
  date_debut             DateTime
  date_fin               DateTime
  statut                 String                 @default("Non démarré")
  avancement             Int                    @default(0)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  adherencesDependant    Adherence[]            @relation("AdherenceDependant")
  adherencesSource       Adherence[]            @relation("AdherenceSource")
  rmds                   ChantierRmd[]
  consultationQuestions  ConsultationQuestion[]
  favoris                FavoriChantier?
  jalons                 Jalon[]
  membres                MembreEquipe[]
  raids                  Raid[]
  saisiesTemps           SaisieTemps[]
  /// Functional (programme) team for this chantier — auto-created 1:1.
  equipeFonctionnelle    Equipe?
}

model Rmd {
  id          String        @id @default(uuid())
  nom_complet String
  domaine     String
  suppleant   String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  chantiers   ChantierRmd[]
}

model ChantierRmd {
  chantierId String
  rmdId      String
  rmd        Rmd      @relation(fields: [rmdId], references: [id], onDelete: Cascade)
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@id([chantierId, rmdId])
}

model ProfilRessource {
  id             String      @id @default(uuid())
  nom            String
  type_ressource String
  tjm_defaut     Float       @default(0)
  ordre          Int         @default(0)
  actif          Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  ressources     Ressource[]

  @@unique([nom, type_ressource])
  @@index([type_ressource])
}

model Ressource {
  id                  String           @id @default(uuid())
  nom_complet         String
  email               String           @default("")
  telephone           String           @default("")
  type                String
  organisation        String           @default("")
  tarif_journalier    Float            @default(0)
  capacite_jours_mois Int              @default(20)
  actif               Boolean          @default(true)
  profilId            String?
  /// Hierarchical home team in the bank (required at application level).
  equipeHierarchieId  String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  membres             MembreEquipe[]
  raids               Raid[]
  profil              ProfilRessource? @relation(fields: [profilId], references: [id])
  equipeHierarchie    Equipe?          @relation("RessourceEquipeHierarchie", fields: [equipeHierarchieId], references: [id], onDelete: SetNull)
  equipesFonctionnelles RessourceEquipeFonctionnelle[]
  saisiesTemps        SaisieTemps[]
  user                User?

  @@index([equipeHierarchieId])
}

/// Functional multi-team membership for a resource (in addition to hierarchical team).
model RessourceEquipeFonctionnelle {
  id          String    @id @default(uuid())
  ressourceId String
  equipeId    String
  createdAt   DateTime  @default(now())
  ressource   Ressource @relation(fields: [ressourceId], references: [id], onDelete: Cascade)
  equipe      Equipe    @relation(fields: [equipeId], references: [id], onDelete: Cascade)

  @@unique([ressourceId, equipeId])
  @@index([equipeId])
}

model User {
  id              String     @id @default(uuid())
  username        String     @unique
  password_hash   String
  /// Identity fields kept in sync with linked Ressource (source of truth for people data).
  first_name      String     @default("")
  last_name       String     @default("")
  phone           String     @default("")
  email           String     @default("")
  /// Public path to avatar image, e.g. /uploads/avatars/{id}.webp — empty = letter fallback
  avatar_url      String     @default("")
  /// Account default UI theme: light | dark (applied on app access; sidebar can still toggle)
  theme_preference String    @default("light")
  role            String     @default("PMO_Chantier")
  must_change_pwd Boolean    @default(true)
  is_active       Boolean    @default(true)
  /// App account is always a Ressource (1:1). Enforced on create; nullable only for legacy rows.
  ressourceId     String?    @unique
  failed_attempts Int        @default(0)
  dashboard_type  String     @default("complete")
  locked_until    DateTime?
  last_login      DateTime?
  created_by      String     @default("")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  ressource       Ressource? @relation(fields: [ressourceId], references: [id])
  notifications   Notification[]
}

/// Per-user in-app notifications (persistent, mark-as-read). Not email.
model Notification {
  id         String    @id @default(uuid())
  userId     String
  /// raid_assigned | raid_changed | …
  type       String
  title      String
  message    String    @default("")
  /// Deep link e.g. /raid/{id}
  href       String    @default("")
  /// Optional entity ref: "raid"
  entityType String    @default("")
  entityId   String    @default("")
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([entityType, entityId])
}

/// Dynamic application role (permissions + data scope)
model AppRole {
  id             String   @id @default(uuid())
  code           String   @unique
  label          String
  description    String   @default("")
  color          String   @default("#6b7280")
  is_active      Boolean  @default(true)
  /// System roles (e.g. Admin) cannot be deleted; Admin cannot be disabled
  is_system      Boolean  @default(false)
  /// Chantier data scope: all | assigned | none
  chantier_scope String   @default("none")
  /// Who may create RAID entries: programme | chantier | none
  /// - programme: any chantier (programme-wide)
  /// - chantier: only chantiers where the user is attached as a Ressource
  /// - none: cannot create RAID (default)
  raid_create_scope String @default("none")
  /// Allowed app page paths (JSON string array)
  pages          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([is_active])
}

model MembreEquipe {
  id                 String    @id @default(uuid())
  chantierId         String
  equipe             String
  role               String
  /// Optional free-text notes for this assignment (not identity — name comes from Ressource).
  commentaires       String    @default("")
  is_directeur       Boolean   @default(false)
  charge_pourcentage Int       @default(100)
  /// Required: every chantier team member must be a known Ressource.
  ressourceId        String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  ressource          Ressource @relation(fields: [ressourceId], references: [id], onDelete: Restrict)
  chantier           Chantier  @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@index([ressourceId])
  @@index([chantierId, ressourceId])
}

model Raid {
  id                     String     @id @default(uuid())
  /// Human-readable code e.g. A_00001, R_00042 (letter by type + 5-digit seq). Immutable after create.
  code                   String     @unique
  type                   String
  intitule               String
  description            String     @default("")
  categorie              String     @default("")
  chantierId             String?
  domaine                String     @default("")
  probabilite            Int?
  impact                 Int?
  strategie              String     @default("")
  mitigation             String     @default("")
  responsable            String     @default("")
  responsableRessourceId String?
  /// Team assignment: chantier functional team if assignee is on that chantier,
  /// otherwise the assignee's institutional (hierarchy) team.
  equipeId               String?
  statut                 String     @default("")
  date_identification    DateTime?
  date_revision          DateTime?
  date_echeance          DateTime?
  commentaires           String     @default("")
  comiteId               String?
  /// Creator (app user) for audit / circulation.
  createdByUserId        String?
  createdByName          String     @default("")
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  comite                 Comite?    @relation(fields: [comiteId], references: [id])
  responsableRessource   Ressource? @relation(fields: [responsableRessourceId], references: [id])
  chantier               Chantier?  @relation(fields: [chantierId], references: [id])
  equipe                 Equipe?    @relation(fields: [equipeId], references: [id], onDelete: SetNull)
  raidComments           RaidComment[]
  auditLogs              RaidAuditLog[]

  @@index([code])
  @@index([responsableRessourceId])
  @@index([equipeId])
  @@index([chantierId])
}

/// Per-type autoincrement for Raid.code (Action→A_, Risque→R_, …).
model RaidCodeSequence {
  type String @id
  last Int    @default(0)
}

/// Collaborative discussion thread on a RAID entry (Jira-style).
model RaidComment {
  id                 String   @id @default(uuid())
  raidId             String
  body               String
  /// System notes (e.g. mandatory status-change comment flagged).
  is_system          Boolean  @default(false)
  authorUserId       String?
  authorName         String   @default("")
  authorRessourceId  String?
  createdAt          DateTime @default(now())
  raid               Raid     @relation(fields: [raidId], references: [id], onDelete: Cascade)

  @@index([raidId, createdAt])
}

/// Immutable audit trail for RAID collaboration (status, assignment, fields, comments).
model RaidAuditLog {
  id                String   @id @default(uuid())
  raidId            String
  /// created | status_changed | assigned | auto_assigned | unassigned | commented | field_updated
  action            String
  field             String   @default("")
  oldValue          String   @default("")
  newValue          String   @default("")
  /// French human-readable summary for timeline & table.
  summary           String
  actorUserId       String?
  actorName         String   @default("")
  actorRessourceId  String?
  createdAt         DateTime @default(now())
  raid              Raid     @relation(fields: [raidId], references: [id], onDelete: Cascade)

  @@index([raidId, createdAt])
}

model Comite {
  id                 String   @id @default(uuid())
  instance           String
  numero             Int
  date               DateTime
  heure_casablanca   String   @default("")
  heure_belgique     String   @default("")
  statut             String   @default("A planifier")
  ordre_du_jour      String   @default("")
  invitation_envoyee Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  raids              Raid[]
}

/// Teams catalog — two kinds:
/// - institutionnelle: bank org units (hierarchy / comité owners)
/// - fonctionnelle: chantier programme team (1:1 with Chantier, auto-created)
model Equipe {
  id          String            @id @default(uuid())
  name        String            @unique
  description String            @default("")
  position    Int               @default(0)
  is_active   Boolean           @default(true)
  /// institutionnelle | fonctionnelle
  type        String            @default("institutionnelle")
  /// Only for fonctionnelle teams — one functional team per chantier.
  chantierId  String?           @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  chantier    Chantier?         @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  comiteParametres ComiteParametre[]
  ressourcesHierarchie Ressource[] @relation("RessourceEquipeHierarchie")
  ressourcesFonctionnelles RessourceEquipeFonctionnelle[]
  raids       Raid[]
  /// Special RAID category access (institutionnelle only). Default empty.
  raidCategorieAccess EquipeRaidCategorieAccess[]

  @@index([position])
  @@index([is_active])
  @@index([type])
}

/// Institutional team → RAID categories they can access beyond normal rules.
/// Empty = no special access (default). Members of the team see/collaborate on
/// all RAID entries whose `categorie` matches a granted option label.
model EquipeRaidCategorieAccess {
  id                String          @id @default(uuid())
  equipeId          String
  raidFieldOptionId String
  createdAt         DateTime        @default(now())
  equipe            Equipe          @relation(fields: [equipeId], references: [id], onDelete: Cascade)
  raidFieldOption   RaidFieldOption @relation(fields: [raidFieldOptionId], references: [id], onDelete: Cascade)

  @@unique([equipeId, raidFieldOptionId])
  @@index([equipeId])
  @@index([raidFieldOptionId])
}

/// Parameter table for committee types (instances) — admin-managed catalog.
model ComiteParametre {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  frequency   String   @default("")
  /// Denormalized team name (kept in sync with Equipe for display / legacy).
  owner       String   @default("")
  equipeId    String?
  /// Short label for tabs / filters (e.g. CTR). Falls back to name in UI if empty.
  short_label String   @default("")
  color       String   @default("#6b7280")
  position    Int      @default(0)
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  equipe      Equipe?  @relation(fields: [equipeId], references: [id], onDelete: SetNull)

  @@index([position])
  @@index([is_active])
  @@index([equipeId])
}

model Settings {
  id                       Int @id @default(autoincrement())
  seuil_relance_jours      Int @default(3)
  seuil_qa_critique_heures Int @default(48)
  poids_precadrage         Int @default(10)
  poids_cadrage            Int @default(20)
  poids_execution          Int @default(50)
  poids_cloture            Int @default(20)
}

model StatusConfig {
  id        String   @id @default(uuid())
  type      String
  label     String
  color     String   @default("#6b7280")
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([type, label])
  @@index([type, position])
}

/// Parametrable RAID dropdown catalogs (Catégorie / Domaine) — admin-managed in /settings.
model RaidFieldOption {
  id        String   @id @default(uuid())
  /// "categorie" | "domaine"
  kind      String
  label     String
  color     String   @default("#6b7280")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  equipeCategorieAccess EquipeRaidCategorieAccess[]

  @@unique([kind, label])
  @@index([kind, position])
}

model SaisieTemps {
  id               String    @id @default(uuid())
  ressourceId      String
  chantierId       String
  date_lundi       DateTime
  jours_travailles Float     @default(0)
  commentaire      String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  chantier         Chantier  @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  ressource        Ressource @relation(fields: [ressourceId], references: [id], onDelete: Cascade)

  @@unique([ressourceId, chantierId, date_lundi])
  @@index([ressourceId, date_lundi])
  @@index([chantierId, date_lundi])
}

model Adherence {
  id                     String    @id @default(uuid())
  code                   String    @unique
  chantierSourceId       String
  chantierDependantId    String?
  chantierDependantLabel String    @default("")
  type                   String
  domaine                String    @default("")
  description            String    @default("")
  criticite              String    @default("MODÉRÉE")
  statut                 String    @default("Planifié")
  date_identification    DateTime?
  date_resolution_prevue DateTime?
  responsable            String    @default("")
  contrat_interface      String    @default("")
  commentaires           String    @default("")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  chantierDependant      Chantier? @relation("AdherenceDependant", fields: [chantierDependantId], references: [id])
  chantierSource         Chantier  @relation("AdherenceSource", fields: [chantierSourceId], references: [id])

  @@index([chantierSourceId])
  @@index([chantierDependantId])
  @@index([criticite])
  @@index([statut])
}

model Jalon {
  id          String    @id @default(uuid())
  chantierId  String
  phase       String
  nom         String
  description String    @default("")
  ordre       Int       @default(0)
  date_cible  DateTime
  date_reelle DateTime?
  statut      String    @default("Planifié")
  livrables   String    @default("")
  commentaire String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chantier    Chantier  @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@index([chantierId])
  @@index([phase])
  @@index([statut])
}

model JalonTemplate {
  id        String   @id @default(uuid())
  phase     String
  nom       String
  ordre     Int      @default(0)
  offsetPct Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phase])
}

model ConsultationQuestion {
  id           String    @id @default(uuid())
  chantierId   String
  dossier_ref  String    @default("")
  question     String
  categorie    String    @default("Générale")
  priorite     String    @default("Moyenne")
  statut       String    @default("Ouverte")
  remontee_par String    @default("")
  affectee_a   String    @default("")
  echeance     DateTime?
  resolution   String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  chantier     Chantier  @relation(fields: [chantierId], references: [id], onDelete: Cascade)

  @@index([chantierId])
  @@index([statut])
  @@index([priorite])
}

model FavoriChantier {
  id         String   @id @default(uuid())
  chantierId String   @unique
  createdAt  DateTime @default(now())
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
}

/// SMTP mail server configuration (per-client / bank). Used by lib/mail for outbound mail.
model MailServerConfig {
  id                       String    @id @default(uuid())
  /// Friendly label, e.g. "BOA Exchange" / "SMTP Client X"
  name                     String    @default("Serveur principal")
  host                     String    @default("")
  port                     Int       @default(587)
  /// Security mode: none | starttls | ssl
  security                 String    @default("starttls")
  auth_user                String    @default("")
  /// Encrypted at rest (aes-256-gcm via SESSION_SECRET); empty = no auth
  auth_password_enc        String    @default("")
  from_email               String    @default("")
  from_name                String    @default("")
  reply_to                 String    @default("")
  /// Reject unauthorized TLS certificates (disable only for lab/self-signed)
  tls_reject_unauthorized  Boolean   @default(true)
  connection_timeout_ms    Int       @default(10000)
  greeting_timeout_ms      Int       @default(10000)
  socket_timeout_ms        Int       @default(30000)
  pool                     Boolean   @default(false)
  max_connections          Int       @default(5)
  /// Optional HELO/EHLO hostname
  local_hostname           String    @default("")
  notes                    String    @default("")
  is_active                Boolean   @default(true)
  /// Only one default used for sendMail() when no config id is passed
  is_default               Boolean   @default(true)
  last_test_at             DateTime?
  last_test_ok             Boolean?
  last_test_message        String    @default("")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([is_default, is_active])
}
